{
  "logicalName": "fma_kpisnapshot",
  "schemaName": "fma_KpiSnapshot",
  "displayName": "KPI Snapshot",
  "displayCollectionName": "KPI Snapshots",
  "description": "Time-series KPI values per client per period. The agent writes here after every scoring run. This is the bridge between raw work order data and maturity scores.",
