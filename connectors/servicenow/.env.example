# ServiceNow instance URL (no trailing slash)
# Format: https://YOUR_INSTANCE.service-now.com
SN_INSTANCE_URL=

# OAuth 2.0 credentials
# Create in ServiceNow: System OAuth → Application Registry
SN_CLIENT_ID=
SN_CLIENT_SECRET=

# Service account credentials
# Account needs read access to wm_order table
SN_USERNAME=
SN_PASSWORD=

# Target Dataverse credentials (shared across all connectors)
FMA_TARGET_DATAVERSE_URL=
FMA_DATAVERSE_TENANT_ID=
FMA_DATAVERSE_CLIENT_ID=
FMA_DATAVERSE_CLIENT_SECRET=

# The fma_client GUID this connector is syncing for
FMA_CLIENT_ID=
