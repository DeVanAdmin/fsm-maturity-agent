# Salesforce Connected App credentials
# Create a Connected App in Salesforce Setup → App Manager
SF_LOGIN_URL=https://login.salesforce.com
SF_CLIENT_ID=
SF_CLIENT_SECRET=
SF_USERNAME=
# Password + Security Token concatenated (no space)
SF_PASSWORD_TOKEN=

# Salesforce API version
SF_API_VERSION=v59.0

# Target Dataverse credentials (same as D365 connector)
FMA_TARGET_DATAVERSE_URL=
FMA_DATAVERSE_TENANT_ID=
FMA_DATAVERSE_CLIENT_ID=
FMA_DATAVERSE_CLIENT_SECRET=

# The fma_client GUID this connector is syncing for
FMA_CLIENT_ID=
