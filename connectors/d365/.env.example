# --- D365 Field Service (SOURCE system) ---

# Azure AD tenant (directory) ID that owns the D365 app registration.
# Azure Portal → Microsoft Entra ID → Overview → Tenant ID.
D365_TENANT_ID=

# Application (client) ID of the app registration used to call the D365 Web API.
# Azure Portal → Microsoft Entra ID → App registrations → your app → Overview.
D365_CLIENT_ID=

# Client secret VALUE for that app registration (store in Key Vault in production).
# Azure Portal → App registrations → your app → Certificates & secrets → New client secret.
D365_CLIENT_SECRET=

# Base URL of the D365 Field Service organization we pull work orders FROM.
# e.g. https://contoso-fs.crm.dynamics.com  (no trailing slash).
D365_ORG_URL=

# --- FMA Dataverse (TARGET system) ---

# Base URL of the target Dataverse org we write normalized fma_workorder rows TO.
# e.g. https://fma-prod.crm.dynamics.com  (no trailing slash).
FMA_TARGET_DATAVERSE_URL=

# GUID of the fma_client record these work orders belong to.
# From the fma_client table in the target Dataverse org (Client → ...id).
FMA_CLIENT_ID=
