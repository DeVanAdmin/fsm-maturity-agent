# IFS deployment type: 'cloud' or 'onpremise'
IFS_DEPLOYMENT_TYPE=cloud

# IFS Cloud OAuth credentials
# Register a client application in IFS Identity Server
IFS_TOKEN_URL=https://YOUR_INSTANCE.ifs.cloud/idp/connect/token
IFS_CLIENT_ID=
IFS_CLIENT_SECRET=
IFS_SCOPE=ifsapp offline_access

# IFS on-premise Basic Auth (only needed if DEPLOYMENT_TYPE=onpremise)
IFS_USERNAME=
IFS_PASSWORD=

# IFS OData base URL
IFS_BASE_URL=https://YOUR_INSTANCE.ifs.cloud/main/ifsapp/data

# Target Dataverse credentials (shared across all connectors)
FMA_TARGET_DATAVERSE_URL=
FMA_DATAVERSE_TENANT_ID=
FMA_DATAVERSE_CLIENT_ID=
FMA_DATAVERSE_CLIENT_SECRET=

# The fma_client GUID this connector is syncing for
FMA_CLIENT_ID=
